# Required
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ALLOWED_ORIGINS=https://demo.yourdomain.com

# Optional OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Optional self-hosted TURN (coturn in docker-compose)
# Used by deploy script to generate VITE_RTC_ICE_SERVERS when it is not set explicitly.
TURN_REALM=vialive.libreuni.com
TURN_PUBLIC_HOST=vialive.libreuni.com
TURN_USERNAME=via-turn
TURN_PASSWORD=change-this-turn-password
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Optional explicit ICE config override (JSON array as one line)
# Example:
# VITE_RTC_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:vialive.libreuni.com:3478?transport=udp","username":"via-turn","credential":"change-this-turn-password"}]'
VITE_RTC_ICE_SERVERS=
