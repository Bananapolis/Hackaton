vialive.libreuni.com {
  tls {
    issuer acme https://acme.zerossl.com/v2/DV90
  }
  encode gzip zstd

  # WHIP (Android broadcaster) and WHEP (student viewer) — proxy to MediaMTX over plain HTTP
  handle /live/* {
    reverse_proxy mediamtx:8889
  }

  handle {
    reverse_proxy web:80
  }
}

dev.vialive.libreuni.com {
  tls {
    issuer acme https://acme.zerossl.com/v2/DV90
  }
  encode gzip zstd

  handle /live/* {
    reverse_proxy mediamtx-dev:8889
  }

  handle {
    reverse_proxy web-dev:80
  }
}
